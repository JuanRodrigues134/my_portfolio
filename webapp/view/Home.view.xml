<mvc:View
    controllerName="com.rrsolutions.myportfolio.controller.Home"
    xmlns:mvc="sap.ui.core.mvc"
    displayBlock="true"
    xmlns:m="sap.m"
    xmlns="sap.uxap">
    <ObjectPageLayout id="idObjPage">
        <headerTitle>
            <ObjectPageDynamicHeaderTitle>
                <expandedContent>
                </expandedContent>
                <snappedContent>
                </snappedContent>
                <snappedHeading>
                </snappedHeading>
            </ObjectPageDynamicHeaderTitle>
        </headerTitle>
        <headerContent>
            <m:HBox
                fitContainer="true"
                alignItems="Center"
                alignContent="SpaceBetween"
                justifyContent="SpaceBetween"
                width="100%">
                <m:HBox>
                    <m:Avatar
                        src="../img/AvatarJuan.png"
                        class="sapUiTinyMarginEnd" />
                    <m:VBox>
                        <m:Title
                            text="{user>/name}"
                            wrapping="true" />
                        <m:Text text="{user>/role}" />
                    </m:VBox>
                </m:HBox>
                <m:HBox>
                    <m:Toolbar design="Transparent">
                        <m:Link text="{i18n>downloadCv}" />
                        <m:ToolbarSeparator />
                        <m:Link
                            text="{i18n>linkedinLink}"
                            href="{user>/linkedin}"
                            target="blank" />
                        <m:ToolbarSeparator />
                        <m:Link
                            text="{i18n>gitHubLink}"
                            href="{user>/gitHub}"
                            target="blank" />
                        <m:ToolbarSeparator />
                        <m:Link text="{user>/email}" />
                    </m:Toolbar>
                </m:HBox>
            </m:HBox>
        </headerContent>
        <sections>
            <ObjectPageSection title="{i18n>aboutMePageSection}">
                <subSections>
                    <ObjectPageSubSection titleUppercase="false">
                        <blocks>
                            <m:Text
                                text="{user>/aboutMe}"
                                width="100%" />
                        </blocks>
                    </ObjectPageSubSection>
                </subSections>
            </ObjectPageSection>
            <ObjectPageSection title="{i18n>experiencePageSection}">
                <subSections>
                    <ObjectPageSubSection titleUppercase="false">
                        <blocks>
                            <m:HBox>
                                <m:Text text="Teste" />
                            </m:HBox>
                        </blocks>
                    </ObjectPageSubSection>
                </subSections>
            </ObjectPageSection>
            <ObjectPageSection title="{i18n>projectsPageSection}">
                <subSections>
                    <ObjectPageSubSection titleUppercase="false">
                        <blocks>
                            <m:HBox>
                                <m:Text text="Teste" />
                            </m:HBox>
                        </blocks>
                    </ObjectPageSubSection>
                </subSections>
            </ObjectPageSection>
            <ObjectPageSection title="{i18n>ratingSkillsPageSection}">
                <subSections>
                    <ObjectPageSubSection titleUppercase="false">
                        <blocks>
                            <m:HBox>
                                <m:Text text="Teste" />
                            </m:HBox>
                        </blocks>
                    </ObjectPageSubSection>
                </subSections>
            </ObjectPageSection>
        </sections>
    </ObjectPageLayout>
</mvc:View>
