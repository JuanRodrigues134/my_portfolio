<mvc:View
    controllerName="com.rrsolutions.myportfolio.controller.Home"
    xmlns:mvc="sap.ui.core.mvc"
    displayBlock="true"
    xmlns:m="sap.m"
    xmlns="sap.uxap">
    <ObjectPageLayout id="idObjPage">
        <headerTitle>
            <ObjectPageDynamicHeaderTitle>
                <expandedHeading>
                    <m:FlexBox
                        fitContainer="true"
                        alignItems="Center">
                        <m:Avatar
                            src="../img/AvatarJuan.png"
                            class="sapUiTinyMarginEnd" />
                        <m:VBox>
                            <m:Title
                                text="{user>/name}"
                                wrapping="true" />
                            <m:Text text="{user>/role}" />
                        </m:VBox>
                    </m:FlexBox>
                </expandedHeading>
                <expandedContent>
                </expandedContent>
                <snappedContent>
                </snappedContent>
                <snappedHeading>
                    <m:FlexBox
                        fitContainer="true"
                        alignItems="Center">
                        <m:Avatar
                            src="../img/AvatarJuan.png"
                            class="sapUiTinyMarginEnd" />
                        <m:VBox>
                            <m:Title
                                text="{user>/name}"
                                wrapping="true" />
                            <m:Text text="{user>/role}" />
                        </m:VBox>
                    </m:FlexBox>
                </snappedHeading>
            </ObjectPageDynamicHeaderTitle>
        </headerTitle>
        <sections>
            <ObjectPageSection title="{i18n>aboutMePageSection}">
                <subSections>
                    <ObjectPageSubSection titleUppercase="false">
                        <blocks>
                            <m:HBox>
                                <m:Text text="Teste" />
                            </m:HBox>
                        </blocks>
                    </ObjectPageSubSection>
                </subSections>
            </ObjectPageSection>
            <ObjectPageSection title="{i18n>experiencePageSection}">
                <subSections>
                    <ObjectPageSubSection titleUppercase="false">
                        <blocks>
                            <m:HBox>
                                <m:Text text="Teste" />
                            </m:HBox>
                        </blocks>
                    </ObjectPageSubSection>
                </subSections>
            </ObjectPageSection>
            <ObjectPageSection title="{i18n>projectsPageSection}">
                <subSections>
                    <ObjectPageSubSection titleUppercase="false">
                        <blocks>
                            <m:HBox>
                                <m:Text text="Teste" />
                            </m:HBox>
                        </blocks>
                    </ObjectPageSubSection>
                </subSections>
            </ObjectPageSection>
            <ObjectPageSection title="{i18n>ratingSkillsPageSection}">
                <subSections>
                    <ObjectPageSubSection titleUppercase="false">
                        <blocks>
                            <m:HBox>
                                <m:Text text="Teste" />
                            </m:HBox>
                        </blocks>
                    </ObjectPageSubSection>
                </subSections>
            </ObjectPageSection>
        </sections>
    </ObjectPageLayout>
</mvc:View>
